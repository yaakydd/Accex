{
  "manifest_version": 3,
  "name": "Accex - Advanced Accessibility Scanner",
  "version": "2.2.0",
  "description": "Professional accessibility scanner with AI-powered recommendations, advanced analytics, and comprehensive WCAG compliance checking.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "contextMenus",
    "commands"
  ],

  "host_permissions": ["http://*/*", "https://*/*"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon48.png",
      "32": "icons/icon48.png",
      "48": "icons/icon48.png",
      "128": "icons/icon48.png"
    },
    "default_title": "Accex Accessibility Scanner"
  },

  "background": {
    "service_worker": "background-enhanced.js"
  },

  "options_page": "options-enhanced.html",

  "commands": {
    "run-scan": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "Run accessibility scan on current page"
    },
    "toggle-highlights": {
      "suggested_key": {
        "default": "Ctrl+Shift+H"
      },
      "description": "Toggle accessibility highlights"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      }
    }
  },

  "icons": {
    "16": "icons/icon48.png",
    "32": "icons/icon48.png",
    "48": "icons/icon48.png",
    "128": "icons/icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-enhanced.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "axe.min.js",
        "recommendations.js",
        "tooltip-styles.css",
        "enhanced-ui.css",
        "error-handler.js",
        "data-manager.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
